{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",

    "rootDir": ".",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "sourceMap": true,
    "declaration": false,

    "verbatimModuleSyntax": false,
    "isolatedModules": false
  },
  "include": ["*.ts", "ingestion"],
  "exclude": ["node_modules", "dist"]
}
